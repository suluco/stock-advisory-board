# ─── Required ────────────────────────────────────────────────────────────────

# Your Anthropic API key — obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Optional ────────────────────────────────────────────────────────────────

# Financial Modeling Prep API key — https://financialmodelingprep.com
# The "demo" key works but has strict rate limits. Get a free key for better reliability.
FMP_API_KEY=demo

# Claude model used for the AI screener and all 10 debate agents (fast + cost-efficient)
CLAUDE_SCREENER_MODEL=claude-haiku-4-5-20251001

# Claude model used for the impartial board judge / final investment plan (higher reasoning quality)
CLAUDE_JUDGE_MODEL=claude-sonnet-4-6
